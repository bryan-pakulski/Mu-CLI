.PHONY: test test-tools test-models test-session test-workspace test-batch

TEST_MUCLI_HOME ?= /tmp/mucli-test
TEST_ENV = MUCLI_HOME=$(TEST_MUCLI_HOME) PYTHONPATH=.

test:
	rm -rf $(TEST_MUCLI_HOME)
	$(TEST_ENV) pytest tests

test-tools:
	rm -rf $(TEST_MUCLI_HOME)
	$(TEST_ENV) pytest tests/test_tools.py tests/test_multi_diff.py

test-models:
	rm -rf $(TEST_MUCLI_HOME)
	$(TEST_ENV) pytest tests/test_gemini.py tests/test_ollama.py

test-session:
	rm -rf $(TEST_MUCLI_HOME)
	$(TEST_ENV) pytest tests/test_session.py

test-workspace:
	rm -rf $(TEST_MUCLI_HOME)
	$(TEST_ENV) pytest tests/test_workspace.py

test-batch:
	rm -rf $(TEST_MUCLI_HOME)
	$(TEST_ENV) pytest tests/test_batch_tool.py
