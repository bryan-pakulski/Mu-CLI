def render_response(text):                                                                                
    """                                                                                                   
    Renders text using Rich.                                                                              
    Text is Markdown formatted.                                                                           
    Code is printed raw (flush left) for easy copying.                                                    
    """                                                                                                   
    if not text.strip():                                                                                  
        return                                                                                            
                                                                                                          
    # Split the text by code blocks                                                                       
    # This regex captures the ```lang ... ``` blocks including the backticks                              
    parts = re.split(r"(```(?:[\w\+\-\.]+)?\s*\n.*?```)", text, flags=re.DOTALL)                          
                                                                                                          
    for part in parts:                                                                                    
        if not part.strip():                                                                              
            continue                                                                                      
                                                                                                          
        if part.startswith("```"):                                                                        
            # --- CODE BLOCK HANDLING ---                                                                 
            lines = part.split("\n")                                                                      
            # Extract language (e.g., ```python -> python)                                                
            language = lines[0].strip("`").strip() or "text"                                              
                                                                                                          
            # Extract code content (remove first and last lines which are ```)                            
            code_content = "\n".join(lines[1:-1])                                                         
                                                                                                          
            # 1. Print a header (pure visual, not part of selection)                                      
            console.print(f" [bold cyan]┌── {language} ─────────────────────────────────[/bold cyan]")    
                                                                                                          
            # 2. Print the Syntax object                                                                  
            # background_color="default" ensures it blends with your terminal                             
            # word_wrap=False ensures long lines don't break copy-paste                                   
            syntax = Syntax(                                                                              
                code_content,                                                                             
                language,                                                                                 
                theme="monokai",                                                                          
                line_numbers=False,                                                                       
                word_wrap=False,                                                                          
                padding=0,                                                                                
                background_color="default"                                                                
            )                                                                                             
            console.print(syntax)                                                                         
                                                                                                          
            # 3. Print a footer                                                                           
            console.print(" [bold cyan]└────────────────────────────────────────────[/bold cyan]")       
                                                                                                          
        else:                                                                                             
            # --- TEXT HANDLING ---                                                                       
            # Render standard markdown for the conversation parts                                         
            md = Markdown(part.strip())                                                                   
            console.print(md)                                                                             
            console.print("") # Add a little breathing room                    


class MemoryEngine:
    def __init__(self, session_name, debug=False):
        self.debug = debug
        self.db_path = os.path.expanduser("~/.gemini_memory")
        if not os.path.exists(self.db_path):
            os.makedirs(self.db_path)

        self.client = chromadb.PersistentClient(path=self.db_path)

        self.ef = embedding_functions.SentenceTransformerEmbeddingFunction(
            model_name="all-MiniLM-L6-v2"
        )

        self.collection = self.client.get_or_create_collection(
            name=session_name,
            embedding_function=self.ef,
            metadata={"hnsw:space": "cosine"}
        )

    def _sliding_window(self, text, chunk_size=100, overlap=20):
        """Splits text into chunks of words with overlap."""
        words = text.split()
        if len(words) <= chunk_size:
            return [text]

        chunks = []
        for i in range(0, len(words), chunk_size - overlap):
            chunk = words[i:i + chunk_size]
            chunks.append(" ".join(chunk))
            if i + chunk_size >= len(words):
                break
        return chunks


    def memorize(self, text, role, turn_index):
        """
        We will still chop the text into chunks for the Vector Database (so we can find specific lines of code or concepts), but we will store the full original text in the metadata of those chunks. When a chunk is found,
        we retrieve the full text of that turn instead of the fragment.                                                                                                                                                      

        This trades a small amount of disk space (text duplication in metadata) for perfect context retrieval.
        """
        if not text.strip(): return

        # Use sliding window for granular vector search, 
        # but we will store the FULL text in metadata to allow full context retrieval.
        chunks = self._sliding_window(text)

        if self.debug:
            console.print(f"[dim][DEBUG] Memorizing Turn {turn_index} ({role}): {len(chunks)} chunks[/dim]")

        ids = []
        documents = []
        metadatas = []

        for i, chunk in enumerate(chunks):
            chunk_id = f"{turn_index}_{i}"
            
            # We still enrich the vector content with temporal context
            enriched_content = f"[Turn {turn_index} {role}]: {chunk}"

            ids.append(chunk_id)
            documents.append(enriched_content)
            metadatas.append({
                "role": role,
                "turn": turn_index,
                "chunk": i,
                "timestamp": time.time(),
                # Store the full original text in every chunk's metadata.
                # This allows us to retrieve the COMPLETE context if any part of it matches.
                "full_text": text 
            })

        if ids:
            self.collection.add(ids=ids, documents=documents, metadatas=metadatas)

    def recall(self, query, n_results=5, threshold=0.75):
        """
        Retrieves relevant memory.
        Enhancement: Returns the FULL text of the matched turns, not just the chunks.
        """
        if self.collection.count() == 0:
            if self.debug:
                console.print("[dim][DEBUG] Memory is empty.[/dim]")
            return []

        if self.debug:
            console.print(f"[dim][DEBUG] Querying memory for: '{query}'[/dim]")

        # 1. Search for best matches using chunks
        results = self.collection.query(
            query_texts=[query],
            n_results=n_results,
            include=["metadatas", "distances"]
        )
 
        if not results or not results['ids'] or not results['ids'][0]:
            if self.debug:
                console.print("[dim][DEBUG] No matches found.[/dim]")
            return []

        # 2. Filter by Threshold & Deduplicate by Turn
        # We want to return unique *Turns*, not unique *Chunks*.
        seen_turns = set()
        unique_memories = []

        raw_ids = results['ids'][0]
        raw_dists = results['distances'][0]
        raw_metas = results['metadatas'][0]

        for id_, dist, meta in zip(raw_ids, raw_dists, raw_metas):
            if dist > threshold:
                if self.debug:
                    console.print(f"[dim][DEBUG] Ignored result {id_}: distance {dist:.3f} > {threshold}[/dim]")
                continue

            turn_id = meta.get('turn')
            
            # If we haven't seen this turn yet, add its full text
            if turn_id not in seen_turns:
                seen_turns.add(turn_id)
                # Retrieve the full text we stored in metadata
                full_text = meta.get('full_text', "")
                if full_text:
                    unique_memories.append({
                        "turn": turn_id,
                        "text": full_text,
                        "role": meta.get('role')
                    })

        # 3. Sort by Turn ID (Chronological)
        unique_memories.sort(key=lambda x: x['turn'])
        
        final_docs = [m['text'] for m in unique_memories]

        if self.debug:
             console.print(f"[dim][DEBUG] Retrieved {len(final_docs)} full memories.[/dim]")

        return final_docs

    def clear(self):
        """Deletes the vector collection for this session."""
        try:
            self.client.delete_collection(self.collection.name)
            # Recreate empty
            self.collection = self.client.create_collection(
                name=self.collection.name,
                embedding_function=self.ef,
                metadata={"hnsw:space": "cosine"}
            )
            if self.debug:
                console.print("[green][DEBUG] Memory collection cleared.[/green]")
        except Exception as e:
            console.print(f"[red]Error clearing memory: {e}")
  
