def calculate_cost(model_name, input_tokens, output_tokens):
    """Calculates estimated cost based on model pricing tiers."""
    # Normalize model name to find pricing (handle variations like -preview)
    pricing = None
    for k, v in PRICING_DB.items():
        if k in model_name:
            pricing = v
            break
    
    if not pricing:
        return None

    # Determine Tier
    is_high_tier = input_tokens > pricing.get("cutoff", 128000)
    
    in_rate = pricing["in_high"] if is_high_tier else pricing["in"]
    out_rate = pricing["out_high"] if is_high_tier else pricing["out"]

    cost = (input_tokens / 1_000_000 * in_rate) + (output_tokens / 1_000_000 * out_rate)
    return cost

def display_image_in_terminal(image_data, mime_type="image/png"):
    """
    Saves image to disk and attempts to display it inline using CLI protocols.
    """
    if not HAS_PIL:
        console.print("[yellow]PIL not installed. Cannot process image bytes.[/yellow]")
        return

    timestamp = int(time.time())
    ext = mimetypes.guess_extension(mime_type) or ".png"
    filename = f"img_{timestamp}{ext}"
    filepath = os.path.join(IMAGE_DIR, filename)

    try:
        # Save to disk
        image = Image.open(io.BytesIO(image_data))
        image.save(filepath)
        
        # 1. Print clickable link (supported by most modern terminals)
        file_url = f"file://{filepath}"
        console.print(f"\n[bold cyan]Image Generated:[/bold cyan] [link={file_url}]{filepath}[/link]")

        # 2. Attempt Inline Display
        # Check for iTerm2 (imgcat)
        term = os.environ.get("TERM_PROGRAM", "")
        if "iTerm" in term:
            # Simple iTerm2 inline image protocol
            b64_data = base64.b64encode(image_data).decode('ascii')
            print(f"\033]1337;File=inline=1:{b64_data}\a")
            return

        # Check for Kitty
        if "kitty" in term:
            try:
                subprocess.run(["kitty", "+kitten", "icat", filepath], check=False)
                return
            except FileNotFoundError:
                pass

        # Check for external tools (timg, catimg)
        if shutil.which("timg"):
            subprocess.run(["timg", "-g", "100x100", filepath], check=False)
        elif shutil.which("catimg"):
            subprocess.run(["catimg", "-w", "100", filepath], check=False)
        else:
            # Fallback: simple size info
            console.print(f"[dim](Image size: {image.size[0]}x{image.size[1]})[/dim]")

    except Exception as e:
        console.print(f"[red]Failed to display image: {e}[/red]")

def render_response(text):                                                                                
    """                                                                                                   
    Renders text using Rich.                                                                              
    """                                                                                                   
    if not text.strip():                                                                                  
        return                                                                                            
                                                                                                          
    parts = re.split(r"(```(?:[\w\+\-\.]+)?\s*\n.*?```)", text, flags=re.DOTALL)                          
                                                                                                          
    for part in parts:                                                                                    
        if not part.strip():                                                                              
            continue                                                                                      
                                                                                                          
        if part.startswith("```"):                                                                        
            lines = part.split("\n")                                                                      
            language = lines[0].strip("`").strip() or "text"                                              
            code_content = "\n".join(lines[1:-1])                                                         
                                                                                                          
            console.print(f" [bold cyan]┌── {language} ─────────────────────────────────[/bold cyan]")    
            syntax = Syntax(                                                                              
                code_content,                                                                             
                language,                                                                                 
                theme="monokai",                                                                          
                line_numbers=False,                                                                       
                word_wrap=False,                                                                          
                padding=0,                                                                                
                background_color="default"                                                                
            )                                                                                             
            console.print(syntax)                                                                         
            console.print(" [bold cyan]└────────────────────────────────────────────[/bold cyan]")       
        else:                                                                                             
            md = Markdown(part.strip())                                                                   
            console.print(md)                                                                             
            console.print("") 

class SotaMemoryEngine:
    """
    Dual Indexing: Stores data in both Chroma (Vector) and BM25 (Keyword).
    """
    def __init__(self, session_name, debug=False):
        self.debug = debug
        self.db_path = os.path.expanduser("~/.gemini_memory")
        if not os.path.exists(self.db_path):
            os.makedirs(self.db_path)

        self.client = chromadb.PersistentClient(path=self.db_path)
        self.ef = embedding_functions.SentenceTransformerEmbeddingFunction(
            model_name="all-MiniLM-L6-v2"
        )
        self.collection = self.client.get_or_create_collection(
            name=session_name,
            embedding_function=self.ef,
            metadata={"hnsw:space": "cosine"}
        )

        self.bm25 = None
        self.bm25_corpus = [] 
        self.bm25_ids = []    
        self._rebuild_bm25()

    def _rebuild_bm25(self):
        existing_data = self.collection.get()
        if existing_data and existing_data['documents']:
            self.bm25_corpus = existing_data['documents']
            self.bm25_ids = existing_data['ids']
            tokenized_corpus = [doc.lower().split() for doc in self.bm25_corpus]
            self.bm25 = BM25Okapi(tokenized_corpus)
        else:
            self.bm25 = None

    def _sliding_window(self, text, chunk_size=150, overlap=30):
        words = text.split()
        if len(words) <= chunk_size:
            return [text]
        chunks = []
        for i in range(0, len(words), chunk_size - overlap):
            chunk = words[i:i + chunk_size]
            chunks.append(" ".join(chunk))
            if i + chunk_size >= len(words):
                break
        return chunks

    def memorize(self, text, role, turn_index):
        if not text.strip(): return

        chunks = self._sliding_window(text)
        
        ids = []
        documents = []
        metadatas = []

        for i, chunk in enumerate(chunks):
            chunk_id = f"{turn_index}_{i}"
            enriched_content = f"[{role.upper()}]: {chunk}"

            ids.append(chunk_id)
            documents.append(enriched_content)
            metadatas.append({
                "role": role,
                "turn": turn_index,
                "chunk_index": i,
                "timestamp": time.time(),
                "full_text": text 
            })

        if ids:
            try:
                self.collection.add(ids=ids, documents=documents, metadatas=metadatas)
                self._rebuild_bm25() 
                if self.debug:
                     console.print(f"[dim][DEBUG] Memorized {len(ids)} chunks.[/dim]")
            except Exception as e:
                console.print(f"[red]Memory Error: {e}[/red]")

    def recall(self, query, n_results=5):
        if self.collection.count() == 0:
            return []

        vector_results = self.collection.query(
            query_texts=[query],
            n_results=n_results * 2 
        )
        
        vector_ranks = {}
        if vector_results['ids']:
            for rank, doc_id in enumerate(vector_results['ids'][0]):
                vector_ranks[doc_id] = rank + 1

        bm25_ranks = {}
        if self.bm25:
            tokenized_query = query.lower().split()
            bm25_scores = self.bm25.get_scores(tokenized_query)
            top_n_indices = sorted(range(len(bm25_scores)), key=lambda i: bm25_scores[i], reverse=True)[:n_results*2]
            
            for rank, idx in enumerate(top_n_indices):
                doc_id = self.bm25_ids[idx]
                bm25_ranks[doc_id] = rank + 1

        fused_scores = {}
        k = 60
        all_ids = set(vector_ranks.keys()) | set(bm25_ranks.keys())
        
        for doc_id in all_ids:
            v_score = 1 / (k + vector_ranks[doc_id]) if doc_id in vector_ranks else 0
            k_score = 1 / (k + bm25_ranks[doc_id]) if doc_id in bm25_ranks else 0
            fused_scores[doc_id] = v_score + k_score

        sorted_ids = sorted(fused_scores.keys(), key=lambda x: fused_scores[x], reverse=True)[:n_results]

        final_texts = []
        seen_turns = set()

        if sorted_ids:
            docs = self.collection.get(ids=sorted_ids, include=['metadatas', 'documents'])
            id_to_meta = {id_: meta for id_, meta in zip(docs['ids'], docs['metadatas'])}
            
            for doc_id in sorted_ids:
                meta = id_to_meta.get(doc_id)
                if not meta: continue
                
                turn_id = meta.get('turn')
                if turn_id not in seen_turns:
                    doc_content = docs['documents'][docs['ids'].index(doc_id)]
                    final_texts.append(doc_content)
                    seen_turns.add(turn_id)

        if self.debug:
            console.print(f"[dim][DEBUG] Hybrid Recall: {len(final_texts)} results.[/dim]")

        return final_texts

    def clear(self):
        self.client.delete_collection(self.collection.name)
        self.collection = self.client.create_collection(
            name=self.collection.name,
            embedding_function=self.ef,
            metadata={"hnsw:space": "cosine"}
        )
        self.bm25 = None
        self.bm25_corpus = []
        self.bm25_ids = []

