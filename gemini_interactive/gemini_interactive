    welcome_text.append("   ______               _       _ \n", style="cyan")
    welcome_text.append("  / ____/___   ____ _  (_)___  (_)\n", style="cyan")
    welcome_text.append(" / / __ / _ \ / __ ` \/ // __ \/ / \n", style="cyan")
    welcome_text.append("/ /_/ //  __// / / / / // / / / /  \n", style="cyan")
    welcome_text.append("\____/ \___//_/ /_/_//_/ /_/_/     \n", style="cyan")
    welcome_text.append("\nInteractive AI CLI\n", style="bold magenta")

    info_grid = f"""
    [bold]System:[/bold] {session_sys}
    [bold]Model:[/bold]  [green]{session_model}[/green]
    [bold]Thinking:[/bold] [green]{session_thinking}[/green]
    """

