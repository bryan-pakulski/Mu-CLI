def get_session_names():
    history_dir = os.path.expanduser("~/.gemini_chats/")
    if not os.path.exists(history_dir):
        return []
    files = glob.glob(os.path.join(history_dir, "*.json"))
    return [os.path.basename(f).replace(".json", "") for f in files]

class DynamicSessionCompleter(Completer):
    def get_completions(self, document, complete_event):
        history_dir = os.path.expanduser("~/.gemini_chats/")
        if not os.path.exists(history_dir):
            return []
        files = glob.glob(os.path.join(history_dir, "*.json"))
        sessions = [os.path.basename(f).replace(".json", "") for f in files]
        
        completer = FuzzyWordCompleter(sessions)
        yield from completer.get_completions(document, complete_event)

class InputHandler:
    def __init__(self):
        path_completer = PathCompleter(expanduser=True)
        session_completer = DynamicSessionCompleter()

        # Build model dict for completer
        model_dict = {m: None for m in KNOWN_MODELS}

        self.completer = NestedCompleter.from_nested_dict({
            '/file': path_completer,
            '/f': path_completer,
            '/clear': None,
            '/clearfiles': None,
            '/view': None,
            '/quit': None,
            '/exit': None,
            '/help': None,
            '/model': model_dict,
            '/reindex': None,
            '/system': None,
            '/thinking': None,
            '/list': None,
            '/load': session_completer,
            '/new': None,
            '/delete': session_completer,
            '/tokens': None,
            '/search': None,
        })

        self.style = Style.from_dict({
            'prompt': 'ansicyan bold',
            'rprompt': 'bg:ansiblue ansiwhite',
            'files': 'ansiyellow',
        })

        history_file = os.path.expanduser("~/.gemini_cli_input_history")
        
        self.kb = KeyBindings()
        
        @self.kb.add('enter')
        def _(event):
            buff = event.current_buffer
            text = buff.text.strip()
            if text.startswith("/"):
                buff.validate_and_handle()
            else:
                buff.insert_text('\n')

        @self.kb.add('escape', 'enter')
        def _(event):
            event.current_buffer.validate_and_handle()

        self.session = PromptSession(
            history=FileHistory(history_file),
            auto_suggest=AutoSuggestFromHistory(),
            completer=self.completer,
            style=self.style,
            key_bindings=self.kb,
            multiline=True, 
        )

    def get_input(self, session_name, staged_files):
        files_text = ""
        if staged_files:
            f_names = ", ".join([f["display_name"] for f in staged_files])
            files_text = f" [Files: {f_names}]"

        message = HTML(
            f"<prompt>[{session_name}]</prompt>"
            f"<files>{files_text}</files> "
            f"<prompt>>>></prompt> "
        )

        def bottom_toolbar():
            return HTML(' <b>[Meta+Enter]</b> or <b>[Esc] [Enter]</b> to submit | <b>/help</b> for commands')

        try:
            return self.session.prompt(
                message,
                bottom_toolbar=bottom_toolbar,
                prompt_continuation=self._prompt_continuation,
            ).strip()
        except KeyboardInterrupt:
            return ""
        except EOFError:
            raise EOFError

    def _prompt_continuation(self, width, line_number, is_soft_wrap):
        return HTML(f'<prompt>{("." * (width - 1)) + " "}</prompt>')


# --- Session Management ---
class SessionManager:
    def __init__(self):
        self.current_session_name = DEFAULT_SESSION_NAME
        self.history = []  
        self.summary_anchor = 0  
        self._load_session(DEFAULT_SESSION_NAME)

    def _get_filepath(self, name):
        return os.path.join(HISTORY_DIR, f"{name}.json")

    def _load_session(self, name):
        filepath = self._get_filepath(name)
        self.current_session_name = name
        self.history = []
        self.summary_anchor = 0

        if os.path.exists(filepath):
            try:
                with open(filepath, "r") as f:
                    data = json.load(f)
                if isinstance(data, list):
                    self.history = data 
                elif isinstance(data, dict):
                    self.history = data.get("history", [])
                    self.summary_anchor = data.get("summary_anchor", 0)
            except (json.JSONDecodeError, IOError):
                self.history = []

    def save_history(self):
        filepath = self._get_filepath(self.current_session_name)
        try:
            data = {
                "history": self.history,
                "summary_anchor": self.summary_anchor
            }
            with open(filepath, "w") as f:
                json.dump(data, f, indent=2)
        except IOError as e:
            console.print(f"[red]Warning: Could not save chat history: {e}") 

    def switch_session(self, name):
        self.save_history() 
        self._load_session(name)
        console.print(f"[green]Switched to session: '{name}'")
        self.view_history()

    def new_session(self, name=None):
        self.save_history() 
        if not name:
            name = f"chat_{int(time.time())}"
        self.current_session_name = name
        self.history = []
        self.save_history() 
        console.print(f"[green]Started new session: '{name}'")

    def list_sessions(self):
        if not os.path.exists(self._get_filepath(self.current_session_name)):
            self.save_history()

        files = glob.glob(os.path.join(HISTORY_DIR, "*.json"))
        console.print("\n[green]=== Available Conversations ===")
        for f in files:
            name = os.path.basename(f).replace(".json", "")
            indicator = "*" if name == self.current_session_name else " "
            mod_time = datetime.fromtimestamp(os.path.getmtime(f)).strftime("%Y-%m-%d %H:%M")
            console.print(f" [cyan]{indicator} {name:<20} [dim]({mod_time})")
        print("")

    def delete_session(self, name):
        if name == self.current_session_name:
            console.print("[red]Cannot delete active session.")
            return

        filepath = self._get_filepath(name)
        if os.path.exists(filepath):
            os.remove(filepath)
            console.print(f"[yellow]Deleted session: '{name}'")
        else:
            console.print(f"[red]Session '{name}' not found.")

    def clear_current_history(self):
        self.history = []
        self.save_history()
        console.print("[green]Current chat history cleared.")

    def view_history(self):
        if not self.history:
            console.print("[yellow]No history in this session.[/yellow]")
            return

        console.print(f"\n[bold underline]Conversation History ({self.current_session_name})[/bold underline]\n", justify="center")
        
        for turn in self.history:
            role = "User" if turn["role"] == "user" else "Gemini"
            style = "blue" if role == "User" else "green"
            align = "right" if role == "User" else "left"

            for part in turn.get("parts", []):
                if "text" in part:
                    console.print(f"[blue][bold] {role}")
                    if role == "User":
                        console.print(Panel(part["text"], title=role, style=style, title_align=align, box=box.ROUNDED))
                    else:
                        render_response(part["text"])
                elif "file_data" in part:
                    mime = part["file_data"].get("mime_type", "file")
                    console.print(f"[dim][Attached File: {mime}][/dim]", justify=align)
            
            print("") 

# --- Helpers ---

def get_safe_mime_type(file_path):
    mime_type, _ = mimetypes.guess_type(file_path)
    try:
        if mime_type is not None:
            if (
                mime_type.startswith("image/")
                or mime_type.startswith("audio/")
                or mime_type.startswith("video/")
                or mime_type == "application/pdf"
            ):
                return mime_type
    except Exception:
        return "text/plain"

    return "text/plain"


def upload_file(client, file_path):
    file_path = file_path.strip("'\"")
    file_path = os.path.expanduser(file_path)

    if not os.path.exists(file_path):
        console.print(f"[red]Error: File '{file_path}' not found.")
        return None

    safe_mime = get_safe_mime_type(file_path)
    console.print(f"[blue]Uploading {file_path} as {safe_mime}...")

    try:
        file_ref = client.files.upload(
            file=file_path, config=types.UploadFileConfig(mime_type=safe_mime)
        )
        console.print("[green]Upload complete.")
        return file_ref
    except Exception as e:
        console.print(f"[red]Upload failed: {e}")
        return None


class Session:

    def __init__(self, client, model, thinking, system_instruction, session_manager, debug=False):
        self.client = client
        self.model = model
        self.thinking = thinking
        self.system_instruction = system_instruction
        self.session_manager = session_manager
        self.debug = debug
        self.memory = SotaMemoryEngine(session_manager.current_session_name, debug)
        self.active_context_window = 6 
        self.staged_files = []
        self.rolling_window_size = 10 

    def add_file(self, file_path):
        uploaded = upload_file(self.client, file_path)
        if uploaded:
            self.staged_files.append(
                {
                    "file_data": {
                        "mime_type": uploaded.mime_type,
                        "file_uri": uploaded.uri,
                    },
                    "display_name": os.path.basename(file_path),
                    "full_path": file_path,
                }
            )

    def clear_files(self):
        self.staged_files = []
        console.print("[green]Staged files cleared.")

    def send_message(self, text):
        # 1. Archive User Message 
        parts = []
        parts.extend([{"file_data": f["file_data"]} for f in self.staged_files])
        if text: parts.append({"text": text})
        
        new_user_message = {"role": "user", "parts": parts}
        
        if text:
            console.print(Panel(text, title="User", style="blue", box=box.ROUNDED, title_align="right"))

        # 2. Retrieve Relevant Context
        context_snippets = []
        if text:
            with console.status("[dim]Searching memory...[/dim]", spinner="dots"):
                context_snippets = self.memory.recall(text, n_results=3)

        # 3. Build Dynamic System Prompt
        dynamic_system_prompt = self.system_instruction
        if context_snippets:
            memory_block = "\n".join([f"<memory_fragment>{m}</memory_fragment>" for m in context_snippets])
            dynamic_system_prompt += (
                f"\n\n<relevant_memory>\n"
                f"The following past conversation details may be relevant. "
                f"Use them to answer but do not explicitly mention retrieving them unless asked.\n"
                f"{memory_block}\n"
                f"</relevant_memory>"
            )
            console.print(f"[dim italic]✓ Injected {len(context_snippets)} past memories.[/dim italic]")

        if text:
            turn_idx = len(self.session_manager.history)
            self.memory.memorize(text, "user", turn_idx)

        # 4. Build Strict Context Window
        recent_history = self.session_manager.history[-self.active_context_window:]
        contents_payload = recent_history + [new_user_message]   

        # Save User Message
        self.session_manager.history.append(new_user_message)
        self.session_manager.save_history()

        t_config = types.ThinkingConfig(thinking_level="high") if self.thinking else types.ThinkingConfig(thinking_level=None)
        gen_config = types.GenerateContentConfig(
            thinking_config=t_config, system_instruction=dynamic_system_prompt
        )

        # 5. Generate with Spinner
        try:
            ai_text = ""
            ai_parts_archive = [] # For history storage

            with console.status(f"[bold green]Generating response ({self.model})...[/bold green]", spinner="aesthetic"):
                response = self.client.models.generate_content(
                    model=self.model, contents=contents_payload, config=gen_config
                )

            # --- RENDER AI RESPONSE ---
            console.print(f"\n[bold green]Gemini ({self.model}):[/bold green]")
            
            # Handle mixed content (Text and Images)
            if response.parts:
                for part in response.parts:
                    if part.text:
                        ai_text += part.text
                        render_response(part.text)
                        ai_parts_archive.append({"text": part.text})
                    
                    # Gemini 3 generated images usually come as inline_data
                    if hasattr(part, 'inline_data') and part.inline_data:
                        display_image_in_terminal(part.inline_data.data, part.inline_data.mime_type)
                        # We don't save binary blobs to JSON history to avoid bloat, 
                        # but we can note it
                        ai_parts_archive.append({"text": "[Image Generated and Saved locally]"})
            
            # Fallback for simple text responses
            elif response.text:
                ai_text = response.text
                render_response(ai_text)
                ai_parts_archive.append({"text": ai_text})

            # --- TOKEN USAGE & PRICING ---
            if response.usage_metadata:
                u = response.usage_metadata
                in_tok = u.prompt_token_count
                out_tok = u.candidates_token_count
                total_tok = u.total_token_count
                
                cost_str = ""
                est_cost = calculate_cost(self.model, in_tok, out_tok)
                if est_cost is not None:
                    cost_str = f"| Est. Cost: [bold yellow]${est_cost:.5f}[/bold yellow]"

                console.print(f"[dim]Tokens: In {in_tok} | Out {out_tok} | Total {total_tok} {cost_str}[/dim]", justify="right")
            
            # --- Memorize AI Response (Text Only) ---
            if ai_text:
                turn_idx = len(self.session_manager.history) 
                self.memory.memorize(ai_text, "model", turn_idx)

            # Archive Model Response
            self.session_manager.history.append(
                {"role": "model", "parts": ai_parts_archive}
            )
            self.session_manager.save_history()
            self.staged_files = []

        except Exception as e:
            # If failed, remove the user message we just added to keep history clean
            if self.session_manager.history and self.session_manager.history[-1] == new_user_message:
                 self.session_manager.history.pop()
            self.session_manager.save_history()
            console.print(f"[bold red]API Error:[/bold red] {e}")
    
