    console.print("[dim]Tip: End a line with '\\' to continue typing on the next line.[/dim]")

def print_splash(session_model, session_thinking, session_sys):
    welcome_text = Text()
    welcome_text.append("   ______               _       _ \n", style="cyan")
    welcome_text.append("  / ____/___   ____ _  (_)___  (_)\n", style="cyan")
    welcome_text.append(" / / __ / _ \ / __ ` \/ // __ \/ / \n", style="cyan")
    welcome_text.append("/ /_/ //  __// / / / / // / / / /  \n", style="cyan")
    welcome_text.append("\____/ \___//_/ /_/_//_/ /_/_/     \n", style="cyan")
    welcome_text.append("\nInteractive AI CLI\n", style="bold magenta")

    info_grid = f"""
    [bold]System:[/bold] {session_sys}
    [bold]Model:[/bold]  [green]{session_model}[/green]
    [bold]Thinking:[/bold] [green]{session_thinking}[/green]
    """

    console.print(Panel(
        Text.assemble(welcome_text, Text.from_markup(info_grid)),
        title="[bold yellow]Welcome[/bold yellow]",
        border_style="cyan",
        box=box.DOUBLE
    ))
    console.print("[dim]Type '/help' for commands.[/dim]\n")

def main():
    parser = argparse.ArgumentParser(description="Interactive Google Gemini CLI")
    parser.add_argument(
        "--model", default="gemini-3-pro-preview", help="Default model"
    )
    parser.add_argument(
        "--thinking", action="store_true", help="Start with thinking mode enabled"
    )
    parser.add_argument(
        "--debug", action="store_true", help="Enable debug output"
    )
    parser.add_argument(
        "--system",
        type=str,
        default="""You are a helpful assistant, answer all questions succinctly,when                                                                                            
  providing code changes only provide new code, don't regenerate whole files unless specifically  
  asked. code should be provided in ``` code blocks along with the language being used in the     
  standard format.""",
        help="Initial system instruction",
    )
    args = parser.parse_args()

    api_key = os.environ.get("GOOGLE_API_KEY")
    if not api_key:
        console.print("[red]Error: GOOGLE_API_KEY not set.")
        sys.exit(1)

    client = genai.Client(api_key=api_key)
    session_manager = SessionManager()
    session = Session(client, args.model, args.thinking, args.system, session_manager, debug=args.debug)

    # --- Readline autocomplete --- #
    input_handler = InputHandler()

    sys_status = "SET" if session.system_instruction else "NONE"
    print_splash(session.model, session.thinking, sys_status)

    while True:
        try:
            user_input = input_handler.get_input(
                session.session_manager.current_session_name, 
                session.staged_files
            ) 

            if not user_input:
                continue

            # Handle Commands
            if user_input.startswith("/"):
                parts = user_input.split(" ", 1)
                cmd = parts[0].lower()
                arg = parts[1] if len(parts) > 1 else ""

                if cmd in ["/quit", "/exit", "/q"]:
                    print("Goodbye!")
                    break

                elif cmd in ["/help", "/h"]:
                    print_help()

                elif cmd in ["/clear", "/c"]:
                    session.session_manager.clear_current_history()
                    session.memory.clear()
                    session.staged_files = []

                elif cmd in ["/view", "/v"]:
                    session.session_manager.view_history()

                # --- File Management ---
                elif cmd in ["/file", "/f", "/add"]:
                    if arg:
                        session.add_file(arg.strip("'\""))
                    else:
                        console.print("[red]Usage: /file <path_to_file>")

                elif cmd in ["/clearfiles", "/cf"]:
                    session.clear_files()

                # --- Session Management ---
                elif cmd in ["/list", "/ls"]:
                    session.session_manager.list_sessions()

                elif cmd in ["/new"]:
                    name = arg.strip() if arg else None
                    session.session_manager.new_session(name)
                    session.memory = MemoryEngine(session.session_manager.current_session_name, debug=args.debug)
                    session.staged_files = []

                elif cmd in ["/load", "/open"]:
                    if arg:
                        session.session_manager.switch_session(arg.strip())
                        session.staged_files = []
                        session.memory = MemoryEngine(session.session_manager.current_session_name, debug=args.debug)
                    else:
                        console.print("[yellow]Usage: /load <session_name>")
                elif cmd in ["/delete", "/rm"]:
                    if arg:
                        session.session_manager.delete_session(arg.strip())
                        # Also wipe memory for that session
                        try:
                            session.memory.client.delete_collection(arg.strip())
                            console.print(f"[dim]Memory index for '{arg.strip()}' deleted.[/dim]")
                        except Exception:
                            pass # Collection might not exist
                    else:
                        console.print("[yellow]Usage: /delete <session_name>")

                # --- Config ---
                elif cmd in ["/system", "/sys"]:
                    if arg:
                        session.system_instruction = arg
                        console.print("[green]System prompt updated.")
                    else:
                        curr = (
                            session.system_instruction
                            if session.system_instruction
                            else "None"
                        )
                        console.print(
                            f"[blue]Current System Prompt:\n{curr}"
                        )

                elif cmd == "/model":
                    if arg:
                        session.model = arg
                        console.print(
                            f"Model changed to: [green]{session.model}"
                        )
                    else:
                        console.print(f"Current model: {session.model}")
                elif cmd == "/reindex":
                    console.print("[yellow]Building vector index from current history...")
                    # Clear existing collection for this session
                    try:
                         session.memory.client.delete_collection(session.session_manager.current_session_name)
                         session.memory = MemoryEngine(session.session_manager.current_session_name)
                    except Exception:
                         pass

                    count = 0
                    for i, turn in enumerate(session.session_manager.history):
                        role = turn['role']
                        text_content = ""
                        for p in turn.get('parts', []):
                            if 'text' in p:
                                text_content += p['text']

                        if text_content:
                            session.memory.memorize(text_content, role, i)
                            count += 1
                    print(f"[green]Indexed {count} turns into vector memory.")
                elif cmd == "/summary":
                    console.print("[yellow]summary: ")
                    console.print(session.session_manager.summary)
                elif cmd in ["/search", "/recall"]:
                    if arg:
                        console.print(f"[cyan]Searching memory for:[/cyan] {arg}")
                        results = session.memory.recall(arg, n_results=5)
                        if results:
                            for i, res in enumerate(results):
                                console.print(Panel(res, title=f"Result {i+1}", border_style="dim"))
                        else:
                            console.print("[yellow]No relevant memories found.[/yellow]")
                    else:
                        console.print("[red]Usage: /search <query>[/red]")
                elif cmd == "/tokens":
                    # Calculate estimated tokens for current context
                    # (This is an approximation based on list length, not actual tokenizer)
                    hist_len = len(session.session_manager.history)
                    anchor = session.session_manager.summary_anchor
                    summary_len = len(session.session_manager.summary.split())
                    
                    print("[yellow]--- Context Stats ---")
                    print(f"Total History Turns: {hist_len}")
                    print(f"Summarized Turns:    {anchor}")
                    print(f"Active Turns (Window): {hist_len - anchor}")
                    print(f"Summary Length:      ~{summary_len} words")
                    print("[dim](Actual token count is displayed after generation)")

                elif cmd == "/thinking":
                    session.thinking = not session.thinking
                    state = "ON" if session.thinking else "OFF"
                    print(f"Thinking mode: [green]{state}")

                else:
                    print(f"[red]Unknown command: {cmd}")

                continue

            # Handle Chat
            session.send_message(user_input)

        except KeyboardInterrupt:
            print("\n(Interrupted. Type /quit to exit)")
        except EOFError:
            print("\nGoodbye!")
            break


if __name__ == "__main__":
    main()
